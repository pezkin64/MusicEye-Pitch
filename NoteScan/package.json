{
  "name": "notescan",
  "version": "2.0.0",
  "description": "Music Eye powered by ZemEmu",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "prebuild:android": "npx expo prebuild --platform android --clean",
    "build:android": "npx eas build -p android --profile production",
    "build:android-aab": "npx eas build -p android --profile production",
    "build:android-apk": "npx eas build -p android --profile preview",
    "test": "jest"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/slider": "5.0.1",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.12",
    "expo-av": "~16.0.8",
    "expo-camera": "~17.0.10",
    "expo-crypto": "~15.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-sharing": "~14.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@expo/ngrok": "^4.1.3",
    "babel-preset-expo": "~54.0.10",
    "patch-package": "^8.0.1"
  },
  "private": true
}
